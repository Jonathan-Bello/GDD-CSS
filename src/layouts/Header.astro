---
import Btn from "../components/Btn.astro";
import Contador from "../components/BtnReact";
---

<header class="header">
  <nav class="nav">
    <a href="/" class="logo">Mi Sitio</a>
    <button class="menu-toggle" aria-label="Abrir menú" onclick="toggleMenu()"
      >☰</button
    >
    <ul class="nav-links">
      <li><a href="/blog">Blog</a></li>
      <li><a href="/contacto">Contacto</a></li>
      <Btn />
      <Contador client:load />

      <!-- <li>
        <BtnReact
          client:only="react"
          label="Boton React"
          color="blue"
          size="medium"
        >
          <Boton slot="astroComponent"> boton astro </Boton>
        </BtnReact>
        <li>
          <BtnVue
            client:only="vue"
            onClick={() => alert("Hola")}
            label="Boton"
            color="green"
            size="medium"
          />
        </li> -->
    </ul>
  </nav>
</header>

<style>
  .header {
    background-color: #4b4848;
    padding: 1rem;
    color: white;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: bold;
    text-decoration: none;
    color: white;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }

  .nav-links li a {
    padding: 1rem;
    text-decoration: none;
    color: white;
    font-weight: 500;
  }

  .nav-links li a:hover {
    text-decoration: underline;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: white;
    font-size: 1.5rem;
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: block;
    }
    .nav-links {
      display: none;
      flex-direction: column;
      background: #4b4848;
      position: absolute;
      top: 60px;
      right: 0;
      width: 100%;
      padding: 1rem 0;
    }
    .nav-links.active {
      display: flex;
    }
  }
</style>

<script>
  const menuToogle = document.querySelector(".menu-toggle");
  if (menuToogle) {
    menuToogle.addEventListener("click", toggleMenu);

    function toggleMenu() {
      const navLinks = document.querySelector(".nav-links");
      navLinks.classList.toggle("active");
    }
  }
</script>
