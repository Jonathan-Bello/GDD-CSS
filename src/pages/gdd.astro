---
import Layout from "../layouts/Layout.astro";
import GddSidebar from "../components/gdd/GddSidebar.astro";
import {
  getGddCollections,
  getSortedCollectionEntries,
} from "../utils/gddCollections";

const collections = await getGddCollections();
const generalEntries = await getSortedCollectionEntries("general");
const featuredEntry = generalEntries[0];
---

<Layout
  title="GDD de Citadel of the Solar Souls | Videojuego educativo de CSS"
  description="Consulta el Game Design Document de Citadel of the Solar Souls: sistemas, narrativa y diseño del serious game para aprender CSS jugando."
  pageType="VideoGame"
>
  <section class="bg-bg-base px-4 py-10 md:px-6 md:py-14">
    <div
      class="container mx-auto grid gap-6 xl:grid-cols-[320px_minmax(0,1fr)] xl:items-start"
    >
      <GddSidebar collections={collections} />

      <section
        class="overflow-hidden rounded-4xl border border-border-organic/20 bg-bg-elevated/70 shadow-[0_28px_90px_rgba(26,26,26,0.25)] backdrop-blur"
      >
        <div
          class="border-b border-border-organic/15 px-6 py-6 md:px-8 md:py-7"
        >
          <p
            class="font-text text-sm font-semibold uppercase tracking-[0.24em] text-accent-strong"
          >
            Bienvenido a Citadel of Solar Souls
          </p>
          <h1
            class="mt-3 font-title text-3xl font-bold text-text-primary md:text-4xl"
          >
            Resumen general del juego y su documentación
          </h1>
          <p
            class="mt-4 max-w-3xl font-text text-base leading-8 text-text-secondary/90 md:text-lg"
          >
            Este GDD reúne toda la visión de Citadel of Solar Souls: un juego
            donde el aprendizaje de CSS se transforma en exploración, decisiones
            y progresión. En el panel lateral encontrarás cada colección del
            proyecto para navegar entre sistemas, narrativa, interfaz y
            evolución del jugador, manteniendo siempre la navegación en la misma
            posición.
          </p>
        </div>

        {
          featuredEntry && (
            <div class="grid gap-6 p-6 md:p-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] lg:p-10">
              <div class="space-y-4">
                <span class="inline-flex rounded-full border border-border-organic/20 bg-bg-overlay/70 px-3 py-1 font-text text-xs font-semibold uppercase tracking-[0.22em] text-accent-strong">
                  Entrada sugerida para comenzar
                </span>
                <h2 class="font-title text-3xl font-bold text-text-primary">
                  {featuredEntry.data.title}
                </h2>
                <p class="font-text text-base leading-8 text-text-secondary/90">
                  {featuredEntry.data.description}
                </p>
                <div class="flex flex-wrap gap-3 pt-2 font-text text-sm text-text-secondary/85">
                  <span class="rounded-full border border-border-organic/20 bg-bg-overlay/70 px-4 py-2">
                    Orden {featuredEntry.data.order}
                  </span>
                  <span class="rounded-full border border-border-organic/20 bg-bg-overlay/70 px-4 py-2">
                    {featuredEntry.data.date.toLocaleDateString("es-MX", {
                      day: "2-digit",
                      month: "long",
                      year: "numeric",
                    })}
                  </span>
                </div>
              </div>

              <div class="flex items-center justify-center rounded-[1.75rem] border border-dashed border-border-organic/25 bg-bg-overlay/80 p-8 text-center">
                <div class="space-y-3">
                  <p class="font-text text-xs font-semibold uppercase tracking-[0.22em] text-accent-strong">
                    Comienza aquí
                  </p>
                  <p class="font-title text-2xl font-bold text-text-primary">
                    Revisa la primera entrada de la colección General
                  </p>
                  <a
                    href={`/gdd/general/${featuredEntry.id}/`}
                    class="inline-flex rounded-xl bg-accent px-5 py-3 font-text text-sm font-semibold text-text-primary transition hover:bg-accent-strong"
                  >
                    Abrir entrada
                  </a>
                </div>
              </div>
            </div>
          )
        }
      </section>
    </div>
    <section class="container mx-auto mt-6 rounded-4xl border border-border-organic/20 bg-bg-overlay/70 p-6 md:p-8">
      <p class="font-text text-sm font-semibold uppercase tracking-[0.24em] text-accent-strong">Proyecto de tesis en desarrollo</p>
      <h2 class="mt-3 font-title text-2xl font-bold text-text-primary">Integracion de Godot, web e inteligencia artificial</h2>
      <p class="mt-3 max-w-4xl font-text leading-8 text-text-secondary/90">Este GDD documenta un prototipo de videojuego educativo de CSS. Godot sostiene la experiencia jugable, la web publica la demo y la documentacion, y Hemis funciona como acompanante de IA contextual y pedagogica. La IA orienta sin sustituir la practica ni las decisiones del estudiante.</p>
      <a href="/uso-academico/" class="mt-5 inline-flex rounded-xl bg-accent px-5 py-3 font-text font-semibold text-text-inverse">Conocer uso academico</a>
    </section>
  </section>
</Layout>
