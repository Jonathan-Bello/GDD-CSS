---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import GddSidebar from "../components/gdd/GddSidebar.astro";

const generalEntries = (await getCollection("general")).sort((a, b) => {
  if (a.data.order !== b.data.order) {
    return a.data.order - b.data.order;
  }
  return a.data.date.getTime() - b.data.date.getTime();
});

const sistemaJuegoEntries = (await getCollection("sistema-juego")).sort(
  (a, b) => {
    if (a.data.order !== b.data.order) {
      return a.data.order - b.data.order;
    }
    return a.data.date.getTime() - b.data.date.getTime();
  },
);

const narrativaEntries = (await getCollection("narrativa")).sort((a, b) => {
  if (a.data.order !== b.data.order) {
    return a.data.order - b.data.order;
  }
  return a.data.date.getTime() - b.data.date.getTime();
});

const progresionEntries = (await getCollection("progresion")).sort((a, b) => {
  if (a.data.order !== b.data.order) {
    return a.data.order - b.data.order;
  }
  return a.data.date.getTime() - b.data.date.getTime();
});

const interfazEntries = (await getCollection("interfaz")).sort((a, b) => {
  if (a.data.order !== b.data.order) {
    return a.data.order - b.data.order;
  }
  return a.data.date.getTime() - b.data.date.getTime();
});

const collections = [
  {
    name: "general",
    label: "General",
    path: "/gdd/",
    entries: generalEntries.map((entry) => ({
      id: entry.id,
      data: {
        title: entry.data.title,
        description: entry.data.description,
        order: entry.data.order,
      },
    })),
  },
  {
    name: "sistema-juego",
    label: "Sistema de Juego",
    path: "/sistema-juego/",
    entries: sistemaJuegoEntries.map((entry) => ({
      id: entry.id,
      data: {
        title: entry.data.title,
        description: entry.data.description,
        order: entry.data.order,
      },
    })),
  },
  {
    name: "narrativa",
    label: "Narrativa",
    path: "/narrativa/",
    entries: narrativaEntries.map((entry) => ({
      id: entry.id,
      data: {
        title: entry.data.title,
        description: entry.data.description,
        order: entry.data.order,
      },
    })),
  },
  {
    name: "progresion",
    label: "Progresión",
    path: "/progresion/",
    entries: progresionEntries.map((entry) => ({
      id: entry.id,
      data: {
        title: entry.data.title,
        description: entry.data.description,
        order: entry.data.order,
      },
    })),
  },
  {
    name: "interfaz",
    label: "Interfaz",
    path: "/interfaz/",
    entries: interfazEntries.map((entry) => ({
      id: entry.id,
      data: {
        title: entry.data.title,
        description: entry.data.description,
        order: entry.data.order,
      },
    })),
  },
];

const featuredEntry = generalEntries[0];
---

<Layout title="GDD | CSS Quest AI">
  <section
    class="bg-bg-base px-4 py-10 md:px-6 md:py-14"
  >
    <div class="container mx-auto space-y-8">
      <div class="max-w-4xl space-y-5">
        <span
          class="inline-flex items-center rounded-full border border-border-organic/35 bg-bg-elevated/25 px-4 py-2 font-text text-sm font-semibold text-text-primary"
        >
          Game Design Document
        </span>
        <div class="space-y-4">
          <h1
            class="font-title text-4xl font-extrabold text-text-primary md:text-5xl lg:text-6xl"
          >
            Explora la documentación completa del juego.
          </h1>
          <p
            class="max-w-3xl font-text text-lg leading-8 text-text-secondary/90 md:text-xl"
          >
            Navega por todas las colecciones del GDD: General, Sistema de Juego,
            Narrativa, Progresión e Interfaz. Cada sección contiene
            documentación detallada ordenada por importancia.
          </p>
        </div>
      </div>

      <div class="grid gap-6 xl:grid-cols-[320px_minmax(0,1fr)] xl:items-start">
        <GddSidebar collections={collections} />

        <section
          class="overflow-hidden rounded-[2rem] border border-border-organic/20 bg-bg-elevated/70 shadow-[0_28px_90px_rgba(26,26,26,0.25)] backdrop-blur"
        >
          <div class="border-b border-border-organic/15 px-6 py-6 md:px-8 md:py-7">
            <p
              class="font-text text-sm font-semibold uppercase tracking-[0.24em] text-accent-strong"
            >
              Inicio de la documentación
            </p>
            <h2
              class="mt-3 font-title text-3xl font-bold text-text-primary md:text-4xl"
            >
              Selecciona una entrada del menú lateral para navegar por el GDD.
            </h2>
            <p
              class="mt-4 max-w-3xl font-text text-base leading-8 text-text-secondary/90 md:text-lg"
            >
              Cada entrada se renderiza con una plantilla preparada para
              contenido, metadatos e imagen destacada. La colección actual es <strong
                >General</strong
              > y ya está lista para crecer con más secciones después.
            </p>
          </div>

          {
            featuredEntry && (
              <div class="grid gap-6 p-6 md:p-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] lg:p-10">
                <div class="space-y-4">
                  <span class="inline-flex rounded-full border border-border-organic/20 bg-bg-overlay/70 px-3 py-1 font-text text-xs font-semibold uppercase tracking-[0.22em] text-accent-strong">
                    Primera entrada sugerida
                  </span>
                  <h3 class="font-title text-3xl font-bold text-text-primary">
                    {featuredEntry.data.title}
                  </h3>
                  <p class="font-text text-base leading-8 text-text-secondary/90">
                    {featuredEntry.data.description}
                  </p>
                  <div class="flex flex-wrap gap-3 pt-2 font-text text-sm text-text-secondary/85">
                    <span class="rounded-full border border-border-organic/20 bg-bg-overlay/70 px-4 py-2">
                      Orden {featuredEntry.data.order}
                    </span>
                    <span class="rounded-full border border-border-organic/20 bg-bg-overlay/70 px-4 py-2">
                      {featuredEntry.data.date.toLocaleDateString("es-MX", {
                        day: "2-digit",
                        month: "long",
                        year: "numeric",
                      })}
                    </span>
                  </div>
                </div>

                <div class="flex items-center justify-center rounded-[1.75rem] border border-dashed border-border-organic/25 bg-bg-overlay/80 p-8 text-center">
                  <div class="space-y-3">
                    <p class="font-text text-xs font-semibold uppercase tracking-[0.22em] text-accent-strong">
                      Plantilla de entrada
                    </p>
                    <p class="font-title text-2xl font-bold text-text-primary">
                      Lista para portada y contenido enriquecido
                    </p>
                    <a
                      href={`/gdd/${featuredEntry.id}`}
                      class="inline-flex rounded-xl bg-accent px-5 py-3 font-text text-sm font-semibold text-text-primary transition hover:bg-accent-strong"
                    >
                      Abrir entrada
                    </a>
                  </div>
                </div>
              </div>
            )
          }
        </section>
      </div>
    </div>
  </section>
</Layout>
