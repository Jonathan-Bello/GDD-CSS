---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contacto | CSS Quest AI">
  <section class="bg-bg-base px-4 py-10 md:px-6 md:py-14">
    <div class="container mx-auto max-w-3xl space-y-6">
      <header
        class="overflow-hidden rounded-4xl border border-border-organic/20 bg-bg-elevated/70 px-6 py-7 shadow-[0_28px_90px_rgba(26,26,26,0.2)] backdrop-blur md:px-8"
      >
        <p
          class="font-text text-sm font-semibold uppercase tracking-[0.24em] text-accent-strong"
        >
          Contacto
        </p>
        <h1 class="mt-3 font-title text-3xl font-bold text-text-primary md:text-4xl">
          Envíanos un mensaje
        </h1>
        <p class="mt-4 font-text text-base leading-8 text-text-secondary/90">
          Este formulario está listo para conectarse con Formspree. Solo cambia la
          URL del <code>action</code> por tu endpoint real y empezarás a recibir
          correos.
        </p>
      </header>

      <section
        class="overflow-hidden rounded-4xl border border-border-organic/20 bg-bg-elevated/70 p-6 shadow-[0_28px_90px_rgba(26,26,26,0.2)] backdrop-blur md:p-8"
      >
        <form
          action="https://formspree.io/f/tu-id"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label
              for="nombre"
              class="mb-2 block font-text text-sm font-semibold text-text-primary"
            >
              Nombre
            </label>
            <input
              id="nombre"
              name="nombre"
              type="text"
              required
              autocomplete="name"
              class="w-full rounded-xl border border-border-organic/30 bg-bg-base px-4 py-3 font-text text-text-primary outline-none ring-0 transition focus:border-accent"
              placeholder="Tu nombre"
            />
          </div>

          <div>
            <label
              for="email"
              class="mb-2 block font-text text-sm font-semibold text-text-primary"
            >
              Correo electrónico
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full rounded-xl border border-border-organic/30 bg-bg-base px-4 py-3 font-text text-text-primary outline-none ring-0 transition focus:border-accent"
              placeholder="tu@email.com"
            />
          </div>

          <div>
            <label
              for="mensaje"
              class="mb-2 block font-text text-sm font-semibold text-text-primary"
            >
              Mensaje
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows="6"
              class="w-full rounded-xl border border-border-organic/30 bg-bg-base px-4 py-3 font-text text-text-primary outline-none ring-0 transition focus:border-accent"
              placeholder="Escribe tu mensaje aquí..."
            ></textarea>
          </div>

          <input type="hidden" name="_subject" value="Nuevo mensaje desde CSS Quest AI" />

          <button
            type="submit"
            class="inline-flex rounded-xl bg-accent px-5 py-3 font-text text-sm font-semibold text-text-primary transition hover:bg-accent-strong"
          >
            Enviar mensaje
          </button>
        </form>
      </section>
    </div>
  </section>
</Layout>
