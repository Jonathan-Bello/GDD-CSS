---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";

import { getEntry, render } from "astro:content";
const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/404");
}

const entrada = await getEntry("interfaz", id);

if (!entrada) {
  return Astro.redirect("/404");
}

const { Content } = await render(entrada);
---

<Layout title={`${entrada.data.title} | CSS Quest AI`}>
  <section
    class="bg-[linear-gradient(180deg,rgba(74,6,5,0.95)_0%,rgba(135,22,21,0.88)_48%,rgba(26,26,26,1)_100%)] px-4 py-10 md:px-6 md:py-14"
  >
    <div class="container mx-auto">
      <a
        href="/interfaz"
        class="inline-flex items-center gap-2 rounded-full border border-primary-300/35 bg-primary-700/25 px-4 py-2 font-text text-sm font-semibold text-primary-100 transition-all hover:border-primary-300/60 hover:bg-primary-700/40"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        Volver a Interfaz
      </a>

      <div class="mt-8 max-w-4xl space-y-5">
        <div class="space-y-4">
          <h1
            class="font-title text-4xl font-extrabold text-neutral-50 md:text-5xl lg:text-6xl"
          >
            {entrada.data.title}
          </h1>
          <p
            class="max-w-3xl font-text text-lg leading-8 text-neutral-100/90 md:text-xl"
          >
            {entrada.data.description}
          </p>
        </div>

        <div
          class="flex flex-wrap gap-4 pt-2 font-text text-sm text-neutral-200/85"
        >
          <span
            class="rounded-full border border-neutral-50/10 bg-neutral-50/5 px-4 py-2"
          >
            Orden {entrada.data.order}
          </span>
          <span
            class="rounded-full border border-neutral-50/10 bg-neutral-50/5 px-4 py-2"
          >
            {
              entrada.data.date.toLocaleDateString("es-MX", {
                day: "2-digit",
                month: "long",
                year: "numeric",
              })
            }
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Cover Image con ViewTransition -->
  {
    entrada.data.coverImage && (
      <section class="px-4 py-8 md:px-6 md:py-12">
        <div class="container mx-auto">
          <div class="overflow-hidden rounded-2xl border border-primary-300/20">
            <img
              src={entrada.data.coverImage}
              alt={entrada.data.title}
              transition:name={`card-image-${entrada.id}`}
              class="h-auto w-full object-cover"
            />
          </div>
        </div>
      </section>
    )
  }

  <!-- Content -->
  <section class="px-4 py-12 md:px-6 md:py-16">
    <div class="container mx-auto max-w-4xl">
      <div
        class="prose prose-invert max-w-none space-y-8 font-text text-neutral-200/90"
      >
        <Content />
      </div>

      <!-- Navigation -->
      <div
        class="mt-16 flex items-center justify-between border-t border-primary-300/15 pt-8"
      >
        <a
          href="/interfaz"
          class="inline-flex items-center gap-2 rounded-lg border border-primary-300/35 bg-primary-700/25 px-6 py-3 font-text font-semibold text-primary-100 transition-all hover:border-primary-300/60 hover:bg-primary-700/40"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          Volver al índice
        </a>

        <a
          href="/interfaz"
          class="inline-flex items-center gap-2 rounded-lg border border-primary-300/35 bg-primary-700/25 px-6 py-3 font-text font-semibold text-primary-100 transition-all hover:border-primary-300/60 hover:bg-primary-700/40"
        >
          Ver todas
          <svg
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .prose {
    --tw-prose-body: rgb(229, 231, 235);
    --tw-prose-headings: rgb(249, 250, 251);
    --tw-prose-lead: rgb(209, 213, 219);
    --tw-prose-links: rgb(244, 63, 94);
    --tw-prose-bold: rgb(249, 250, 251);
    --tw-prose-counters: rgb(107, 114, 128);
    --tw-prose-bullets: rgb(107, 114, 128);
    --tw-prose-hr: rgb(75, 85, 99);
    --tw-prose-quotes: rgb(209, 213, 219);
    --tw-prose-quote-borders: rgb(75, 85, 99);
    --tw-prose-captions: rgb(156, 163, 175);
    --tw-prose-code: rgb(226, 232, 240);
    --tw-prose-pre-bg: rgb(15, 23, 42);
    --tw-prose-pre-border: rgb(51, 65, 85);
    --tw-prose-th-borders: rgb(75, 85, 99);
    --tw-prose-td-borders: rgb(75, 85, 99);
  }

  .prose h2 {
    @apply font-title text-2xl font-bold text-neutral-50 md:text-3xl;
  }

  .prose h3 {
    @apply font-title text-xl font-bold text-neutral-100 md:text-2xl;
  }

  .prose h4 {
    @apply font-title text-lg font-bold text-neutral-200 md:text-xl;
  }

  .prose p {
    @apply font-text text-base leading-8;
  }

  .prose ul,
  .prose ol {
    @apply space-y-3;
  }

  .prose li {
    @apply font-text text-base leading-8;
  }

  .prose code {
    @apply rounded bg-neutral-900/50 px-2 py-1 text-sm font-mono text-primary-200;
  }

  .prose pre {
    @apply overflow-x-auto rounded-lg border border-primary-300/20 bg-neutral-900/50 p-4;
  }

  .prose table {
    @apply w-full border-collapse;
  }

  .prose th,
  .prose td {
    @apply border border-primary-300/20 px-4 py-3 text-left;
  }

  .prose th {
    @apply bg-primary-900/20 font-semibold;
  }
</style>
