---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import EntryCard from "../components/EntryCard.astro";

const progresionEntries = (await getCollection("progresion")).sort((a, b) => {
  if (a.data.order !== b.data.order) {
    return a.data.order - b.data.order;
  }
  return a.data.date.getTime() - b.data.date.getTime();
});
---

<Layout title="Progresión | CSS Quest AI">
  <section
    class="bg-[linear-gradient(180deg,rgba(74,6,5,0.95)_0%,rgba(135,22,21,0.88)_48%,rgba(26,26,26,1)_100%)] px-4 py-10 md:px-6 md:py-14"
  >
    <div class="container mx-auto space-y-8">
      <div class="max-w-4xl space-y-5">
        <span
          class="inline-flex items-center rounded-full border border-primary-300/35 bg-primary-700/25 px-4 py-2 font-text text-sm font-semibold text-primary-100"
        >
          Player Progression
        </span>
        <div class="space-y-4">
          <h1
            class="font-title text-4xl font-extrabold text-neutral-50 md:text-5xl lg:text-6xl"
          >
            Diseño de la progresión del jugador.
          </h1>
          <p
            class="max-w-3xl font-text text-lg leading-8 text-neutral-100/90 md:text-xl"
          >
            Aprende cómo está diseñada la curva de dificultad, el sistema de
            misiones y la estructura de progresión del juego.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="px-4 py-12 md:px-6 md:py-16">
    <div class="container mx-auto">
      <!-- Header -->
      <div
        class="mb-12 overflow-hidden rounded-[2rem] border border-primary-300/20 bg-neutral-50/6 shadow-[0_28px_90px_rgba(26,26,26,0.25)] backdrop-blur"
      >
        <div class="border-b border-primary-300/15 px-6 py-6 md:px-8 md:py-7">
          <p
            class="font-text text-sm font-semibold uppercase tracking-[0.24em] text-primary-300"
          >
            Inicio de documentación
          </p>
          <h2
            class="mt-3 font-title text-3xl font-bold text-neutral-50 md:text-4xl"
          >
            Entradas Disponibles
          </h2>
          <p
            class="mt-4 max-w-3xl font-text text-base leading-8 text-neutral-200/90 md:text-lg"
          >
            Conoce los detalles sobre cómo los jugadores progresan a través del
            juego y qué los motiva a continuar.
          </p>
        </div>

        <!-- Grid de Cards -->
        <div class="p-6 md:p-8 lg:p-10">
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {
              progresionEntries.map((entry) => (
                <EntryCard
                  id={entry.id}
                  title={entry.data.title}
                  description={entry.data.description}
                  coverImage={entry.data.coverImage}
                  order={entry.data.order}
                />
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
