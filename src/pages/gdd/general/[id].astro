---
import { render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import GddSidebar from "@components/gdd/GddSidebar.astro";
import GddEntryView from "@components/gdd/GddEntryView.astro";
import {
  getGddCollectionMeta,
  getGddCollections,
  getSortedCollectionEntries,
  type GddSidebarCollection,
} from "@utils/gddCollections";

const generalEntries = await getSortedCollectionEntries("general");
const allCollections = await getGddCollections();
const collectionMeta = getGddCollectionMeta("general");

export async function getStaticPaths() {
  const entries = await getSortedCollectionEntries("general");
  const collections = await getGddCollections();

  return entries.map((entry) => ({
    params: { id: entry.id },
    props: {
      entry,
      collections,
    },
  }));
}

const { entry, collections = allCollections } = Astro.props as {
  entry?: (typeof generalEntries)[number];
  collections?: GddSidebarCollection[];
};

const currentEntry =
  entry ||
  (Astro.params.id
    ? generalEntries.find((item) => item.id === Astro.params.id)
    : null);

if (!currentEntry) {
  return Astro.redirect("/404");
}

const { Content } = await render(currentEntry);
---

<Layout title={`GDD | ${currentEntry.data.title}`}>
  <section class="bg-bg-base px-4 py-10 md:px-6 md:py-14">
    <div
      class="container mx-auto grid gap-6 xl:grid-cols-[320px_minmax(0,1fr)] xl:items-start"
    >
      <GddSidebar collections={collections} currentId={currentEntry.id} />

      <GddEntryView entry={currentEntry} collectionLabel={collectionMeta.label}>
        <Content />
      </GddEntryView>
    </div>
  </section>
</Layout>
