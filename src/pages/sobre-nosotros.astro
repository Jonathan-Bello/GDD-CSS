---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import imgJonathan from "@assets/imgs/team/yo.webp";
import imgJhonna from "@assets/imgs/team/jhonna.webp";
import imgRobert from "@assets/imgs/team/robert.webp";
import imgJorge from "@assets/imgs/team/jorge.webp";

const team = [
  { name: "Jonathan Alexis Bello L\u00f3pez", role: "Autor, director de proyecto y desarrollador principal", description: "Con la marca Jonathan Bello, dirige el proyecto de tesis y articula Godot, tecnologias web e inteligencia artificial para construir un videojuego educativo de CSS.", image: imgJonathan },
  { name: "Jhonnatan L\u00f3pez Aguilar", role: "Guionista y responsable de narrativa", description: "Desarrolla el lore, el guion y la narrativa que integran el aprendizaje de CSS en el universo de Citadel of the Solar Souls.", image: imgJhonna },
  { name: "Roberto Corona Simbron", role: "Colaborador tecnico y validacion de sistemas", description: "Apoya la revision tecnica, la validacion de sistemas y el fortalecimiento de la base funcional del prototipo y su GDD.", image: imgRobert },
  { name: "Jorge Eduardo V\u00e1zquez Vicente", role: "Apoyo academico, desarrollo y Hubs", description: "Colabora en el desarrollo y apoyo academico del proyecto, con participacion en la construccion del apartado de Hubs.", image: imgJorge },
];
---

<Layout title="Equipo | Citadel of the Solar Souls" description="Conoce al equipo de Citadel of the Solar Souls, proyecto de tesis en desarrollo que integra Godot, web e inteligencia artificial en un videojuego educativo de CSS." pageType="VideoGame">
  <section class="bg-bg-base px-4 py-10 md:px-6 md:py-14">
    <div class="container mx-auto max-w-6xl space-y-8">
      <header class="rounded-4xl border border-border-organic/20 bg-bg-elevated/70 px-6 py-8 shadow-[0_28px_90px_rgba(26,26,26,0.2)] md:px-10">
        <p class="font-text text-sm font-semibold uppercase tracking-[0.24em] text-accent-strong">Equipo del proyecto</p>
        <h1 class="mt-3 font-title text-3xl font-bold text-text-primary md:text-4xl">Personas detras de Citadel of the Solar Souls</h1>
        <p class="mt-4 max-w-3xl font-text text-base leading-8 text-text-secondary/90">Somos un equipo multidisciplinario que desarrolla un proyecto de tesis sobre un videojuego educativo de CSS. Combinamos desarrollo en Godot, tecnologias web, inteligencia artificial, narrativa y validacion academica.</p>
      </header>
      <div class="grid gap-6 md:grid-cols-2">
        {team.map((member) => (
          <article class="overflow-hidden rounded-4xl border border-border-organic/20 bg-bg-elevated/70 shadow-[0_20px_60px_rgba(26,26,26,0.18)]">
            <Image src={member.image} alt={`Retrato de ${member.name}`} loading="lazy" decoding="async" class="aspect-[4/3] w-full object-cover object-top" />
            <div class="p-6">
              <h2 class="font-title text-2xl font-bold text-text-primary">{member.name}</h2>
              <p class="mt-2 font-text text-xs font-semibold uppercase tracking-[0.18em] text-accent-strong">{member.role}</p>
              <p class="mt-4 font-text text-base leading-8 text-text-secondary/90">{member.description}</p>
            </div>
          </article>
        ))}
      </div>
      <section class="rounded-4xl border border-border-organic/20 bg-bg-overlay/70 p-6 md:p-8">
        <h2 class="font-title text-2xl font-bold text-text-primary">Proyecto academico en desarrollo</h2>
        <p class="mt-3 font-text leading-8 text-text-secondary/90">El equipo continua la construccion y validacion del prototipo. El objetivo es evaluar como un serious game con IA contextual puede apoyar el aprendizaje de CSS sin reemplazar la practica, el criterio ni la autonomia del estudiante.</p>
      </section>
    </div>
  </section>
</Layout>
