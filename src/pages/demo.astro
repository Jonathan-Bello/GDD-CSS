---
import Layout from "../layouts/Layout.astro";

const gameUrl = "/css-game/index.html";
---

<Layout title="Demo jugable | Citadel of Solar Souls">
  <section class="demo-page bg-neutral-950 text-neutral-50">
    <div class="demo-shell">
      <div class="demo-copy">
        <p class="eyebrow">Demo web</p>
        <h1>Citadel of Solar Souls</h1>
        <p>
          Prueba el primer tramo jugable: introduccion narrativa, exploracion inicial,
          pilar solar, editor CSS y cierre de demo.
        </p>
      </div>

      <div class="demo-frame-wrap" aria-label="Demo jugable integrada">
        <iframe
          src={gameUrl}
          title="Demo jugable de Citadel of Solar Souls"
          loading="eager"
          allow="autoplay; fullscreen; gamepad"
          allowfullscreen
        ></iframe>
      </div>

      <div class="demo-actions">
        <a href={gameUrl} target="_blank" rel="noreferrer">Abrir en pantalla completa</a>
        <span>Recomendado: jugar en escritorio con teclado y mouse.</span>
      </div>
    </div>
  </section>
</Layout>

<style>
  .demo-page {
    min-height: calc(100vh - 4rem);
    padding: 2rem clamp(1rem, 4vw, 4rem) 4rem;
  }

  .demo-shell {
    margin: 0 auto;
    max-width: 1440px;
  }

  .demo-copy {
    display: grid;
    gap: 0.7rem;
    max-width: 840px;
    margin-bottom: 1.25rem;
  }

  .eyebrow {
    color: #76e1a9;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    font-family: Poppins, sans-serif;
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 800;
    line-height: 1;
  }

  .demo-copy p:not(.eyebrow) {
    color: rgba(248, 251, 255, 0.78);
    max-width: 760px;
    font-size: clamp(1rem, 1.5vw, 1.18rem);
  }

  .demo-frame-wrap {
    overflow: hidden;
    border: 1px solid rgba(118, 225, 169, 0.42);
    background: #000;
    box-shadow: 0 22px 70px rgba(0, 0, 0, 0.42);
    aspect-ratio: 16 / 9;
  }

  iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    background: #000;
  }

  .demo-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
    color: rgba(248, 251, 255, 0.68);
    font-size: 0.95rem;
  }

  .demo-actions a {
    border: 1px solid rgba(255, 183, 98, 0.56);
    background: rgba(240, 127, 21, 0.16);
    color: #ffb762;
    padding: 0.7rem 1rem;
    font-weight: 700;
    text-decoration: none;
  }

  .demo-actions a:hover {
    background: rgba(240, 127, 21, 0.25);
  }

  @media (max-width: 760px) {
    .demo-page {
      padding-inline: 0.75rem;
    }

    .demo-frame-wrap {
      aspect-ratio: 4 / 3;
    }
  }
</style>
