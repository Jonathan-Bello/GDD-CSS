---
interface EntryItem {
  id: string;
  data: {
    title: string;
    description: string;
    order: number;
  };
}

interface Collection {
  name: string;
  label: string;
  path: string;
  entries: EntryItem[];
}

interface Props {
  collections?: Collection[];
  currentId?: string;
}

const { collections = [], currentId } = Astro.props;
const totalEntries = Array.isArray(collections)
  ? collections.reduce((total, col) => total + (col?.entries?.length || 0), 0)
  : 0;
---

<aside
  class="rounded-3xl border border-border-organic/20 bg-neutral-50/6 p-4 shadow-[0_24px_80px_rgba(26,26,26,0.24)] backdrop-blur md:p-5 lg:sticky lg:top-24"
>
  <div class="mb-4 flex items-center justify-between gap-3">
    <div>
      <p
        class="font-text text-sm font-semibold uppercase tracking-[0.24em] text-accent-strong"
      >
        Documentación
      </p>
      <h2 class="font-title text-2xl font-bold text-neutral-50">Colecciones</h2>
    </div>
    <span
      class="rounded-full border border-border-organic/30 bg-bg-elevated/20 px-3 py-1 font-text text-xs font-semibold text-text-primary"
    >
      {totalEntries} entradas
    </span>
  </div>

  <div class="space-y-3">
    {
      Array.isArray(collections) && collections.length > 0 ? (
        collections.map((collection) => (
          <details
            class="group overflow-hidden rounded-2xl border border-border-organic/20 bg-neutral-50/5"
            open
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-4 font-title text-lg font-semibold text-neutral-50 transition hover:bg-neutral-50/5">
              <span>{collection.label}</span>
              <svg
                class="size-5 text-accent-strong transition group-open:rotate-180"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="m5 7.5 5 5 5-5"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </summary>

            {Array.isArray(collection?.entries) &&
            collection.entries.length > 0 ? (
              <div class="space-y-2 border-t border-border-organic/15 px-3 py-3">
                {collection.entries.map((entry) => {
                  const isActive = entry.id === currentId;

                  return (
                    <a
                      href={`${collection.path}${entry.id}`}
                      class:list={[
                        "group flex items-start gap-3 rounded-2xl border px-3 py-3 transition",
                        isActive
                          ? "border-border-organic/50 bg-bg-elevated/25 shadow-[0_0_0_1px_rgba(255,199,198,0.12)]"
                          : "border-transparent bg-transparent hover:border-border-organic/20 hover:bg-neutral-50/5",
                      ]}
                      aria-current={isActive ? "page" : undefined}
                    >
                      <span
                        class:list={[
                          "mt-1 inline-flex size-7 shrink-0 items-center justify-center rounded-full border font-text text-xs font-bold",
                          isActive
                            ? "border-border-organic/50 bg-accent/20 text-text-primary"
                            : "border-border-organic/25 bg-neutral-50/5 text-accent-strong",
                        ]}
                      >
                        {entry.data.order}
                      </span>
                      <span class="space-y-1">
                        <span class="block font-text text-sm font-semibold leading-snug text-neutral-50">
                          {entry.data.title}
                        </span>
                        <span class="block font-text text-xs leading-relaxed text-neutral-200/80">
                          {entry.data.description}
                        </span>
                      </span>
                    </a>
                  );
                })}
              </div>
            ) : (
              <div class="border-t border-border-organic/15 px-3 py-3 text-center">
                <p class="font-text text-xs text-neutral-200/60">
                  Sin entradas
                </p>
              </div>
            )}
          </details>
        ))
      ) : (
        <p class="text-center font-text text-sm text-neutral-200/80">
          No hay colecciones disponibles
        </p>
      )
    }
  </div>
</aside>
