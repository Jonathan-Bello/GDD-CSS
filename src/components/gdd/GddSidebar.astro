---
import type { GddSidebarCollection, GddSidebarEntry } from "../../utils/gddCollections";

interface Props {
  collections?: GddSidebarCollection[];
  currentId?: string;
}

const { collections = [], currentId } = Astro.props;
const totalEntries = Array.isArray(collections)
  ? collections.reduce((total, col) => total + (col?.entries?.length || 0), 0)
  : 0;

const getGroupedEntries = (entries: GddSidebarEntry[]) => {
  const parentEntries = entries.filter((entry) => entry.data.isParent);
  const parentIds = new Set(parentEntries.map((entry) => entry.id));

  const childrenByParent = new Map<string, GddSidebarEntry[]>();
  entries
    .filter((entry) => entry.data.parentId && parentIds.has(entry.data.parentId))
    .forEach((entry) => {
      const parentId = entry.data.parentId as string;
      const current = childrenByParent.get(parentId) ?? [];
      current.push(entry);
      childrenByParent.set(parentId, current);
    });

  const ungroupedEntries = entries.filter(
    (entry) =>
      !entry.data.isParent &&
      (!entry.data.parentId || !parentIds.has(entry.data.parentId)),
  );

  return {
    parentEntries,
    childrenByParent,
    ungroupedEntries,
  };
};
---

<aside
  class="rounded-3xl border border-border-organic/20 bg-bg-elevated/70 p-4 shadow-[0_24px_80px_rgba(26,26,26,0.24)] backdrop-blur md:p-5 lg:sticky lg:top-24"
>
  <div class="mb-4 flex items-center justify-between gap-3">
    <div>
      <p
        class="font-text text-sm font-semibold uppercase tracking-[0.24em] text-accent-strong"
      >
        Documentación
      </p>
      <h2 class="font-title text-2xl font-bold text-text-primary">Colecciones</h2>
    </div>
    <span
      class="rounded-full border border-border-organic/30 bg-bg-elevated/20 px-3 py-1 font-text text-xs font-semibold text-text-primary"
    >
      {totalEntries} entradas
    </span>
  </div>

  <div class="space-y-3">
    {
      Array.isArray(collections) && collections.length > 0 ? (
        collections.map((collection) => {
          const hasCurrentEntry =
            typeof currentId === "string" &&
            Array.isArray(collection?.entries) &&
            collection.entries.some((entry) => entry.id === currentId);

          const { parentEntries, childrenByParent, ungroupedEntries } = getGroupedEntries(
            collection.entries,
          );

          const renderEntry = (entry: GddSidebarEntry, isChild = false) => {
            const isActive = entry.id === currentId;

            return (
              <a
                href={`${collection.path}${entry.id}`}
                class:list={[
                  "group flex items-start gap-3 rounded-2xl border px-3 py-3 transition",
                  isChild ? "ml-4" : "",
                  isActive
                    ? "border-border-organic/50 bg-bg-elevated/25 shadow-[0_0_0_1px_rgba(255,199,198,0.12)]"
                    : "border-transparent bg-transparent hover:border-border-organic/20 hover:bg-bg-overlay/70",
                ]}
                aria-current={isActive ? "page" : undefined}
              >
                <span
                  class:list={[
                    "mt-1 inline-flex size-7 shrink-0 items-center justify-center rounded-full border font-text text-xs font-bold",
                    isActive
                      ? "border-border-organic/50 bg-accent/20 text-text-primary"
                      : "border-border-organic/25 bg-bg-overlay/70 text-accent-strong",
                  ]}
                >
                  {entry.data.order}
                </span>
                <span class="space-y-1">
                  <span class="block font-text text-sm font-semibold leading-snug text-text-primary">
                    {entry.data.title}
                  </span>
                  <span class="block font-text text-xs leading-relaxed text-text-secondary/80">
                    {entry.data.description}
                  </span>
                </span>
              </a>
            );
          };

          return (
            <details
              class="group overflow-hidden rounded-2xl border border-border-organic/20 bg-bg-overlay/70"
              open={hasCurrentEntry}
            >
              <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-4 font-title text-lg font-semibold text-text-primary transition hover:bg-bg-overlay/70">
                <span>{collection.label}</span>
                <svg
                  class="size-5 text-accent-strong transition group-open:rotate-180"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="m5 7.5 5 5 5-5"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </summary>

              {Array.isArray(collection?.entries) &&
              collection.entries.length > 0 ? (
                <div class="space-y-2 border-t border-border-organic/15 px-3 py-3">
                  {parentEntries.map((parent) => (
                    <div class="space-y-2">
                      {renderEntry(parent)}
                      {(childrenByParent.get(parent.id) ?? []).map((child) =>
                        renderEntry(child, true),
                      )}
                    </div>
                  ))}

                  {ungroupedEntries.length > 0 && (
                    <div class="space-y-2">
                      {ungroupedEntries.map((entry) => renderEntry(entry))}
                    </div>
                  )}
                </div>
              ) : (
                <div class="border-t border-border-organic/15 px-3 py-3 text-center">
                  <p class="font-text text-xs text-text-secondary/60">
                    Sin entradas
                  </p>
                </div>
              )}
            </details>
          );
        })
      ) : (
        <p class="text-center font-text text-sm text-text-secondary/80">
          No hay colecciones disponibles
        </p>
      )
    }
  </div>
</aside>
