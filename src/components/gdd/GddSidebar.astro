---
interface EntryItem {
  id: string;
  data: {
    title: string;
    description: string;
    order: number;
  };
}

interface Props {
  entries: EntryItem[];
  currentId?: string;
}

const { entries, currentId } = Astro.props;
---

<aside class="rounded-3xl border border-primary-300/20 bg-neutral-50/6 p-4 shadow-[0_24px_80px_rgba(26,26,26,0.24)] backdrop-blur md:p-5 lg:sticky lg:top-24">
  <div class="mb-4 flex items-center justify-between gap-3">
    <div>
      <p class="font-text text-sm font-semibold uppercase tracking-[0.24em] text-primary-300">
        Documentación
      </p>
      <h2 class="font-title text-2xl font-bold text-neutral-50">Colecciones</h2>
    </div>
    <span class="rounded-full border border-primary-300/30 bg-primary-700/20 px-3 py-1 font-text text-xs font-semibold text-primary-100">
      {entries.length} entradas
    </span>
  </div>

  <details class="group overflow-hidden rounded-2xl border border-primary-300/20 bg-neutral-50/5" open>
    <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-4 font-title text-lg font-semibold text-neutral-50 transition hover:bg-neutral-50/5">
      <span>General</span>
      <svg class="size-5 text-primary-300 transition group-open:rotate-180" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="m5 7.5 5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </summary>

    <div class="space-y-2 border-t border-primary-300/15 px-3 py-3">
      {entries.map((entry) => {
        const isActive = entry.id === currentId;

        return (
          <a
            href={`/gdd/${entry.id}`}
            class:list={[
              "group flex items-start gap-3 rounded-2xl border px-3 py-3 transition",
              isActive
                ? "border-primary-300/50 bg-primary-700/25 shadow-[0_0_0_1px_rgba(255,199,198,0.12)]"
                : "border-transparent bg-transparent hover:border-primary-300/20 hover:bg-neutral-50/5",
            ]}
            aria-current={isActive ? "page" : undefined}
          >
            <span class:list={[
              "mt-1 inline-flex size-7 shrink-0 items-center justify-center rounded-full border font-text text-xs font-bold",
              isActive
                ? "border-primary-200/50 bg-primary-500/20 text-primary-100"
                : "border-primary-300/25 bg-neutral-50/5 text-primary-300",
            ]}>
              {entry.data.order}
            </span>
            <span class="space-y-1">
              <span class="block font-text text-sm font-semibold leading-snug text-neutral-50">
                {entry.data.title}
              </span>
              <span class="block font-text text-xs leading-relaxed text-neutral-200/80">
                {entry.data.description}
              </span>
            </span>
          </a>
        );
      })}
    </div>
  </details>
</aside>
