---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface EntryData {
  title: string;
  description: string;
  date: Date;
  order: number;
  coverImage?: ImageMetadata;
}

interface Props {
  entry: {
    id: string;
    data: EntryData;
  };
  collectionLabel?: string;
  children?: unknown;
}

const { entry, collectionLabel = "General" } = Astro.props;
---

<article
  class="overflow-hidden rounded-4xl border border-border-organic/20 bg-bg-elevated/70 shadow-[0_28px_90px_rgba(26,26,26,0.25)] backdrop-blur"
>
  <div class="grid gap-0 xl:grid-cols-[1.25fr_0.95fr]">
    <div class="space-y-6 p-6 md:p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-3">
        <span
          class="rounded-full border border-border-organic/35 bg-bg-elevated/25 px-3 py-1 font-text text-xs font-semibold uppercase tracking-[0.22em] text-text-primary"
        >
          {collectionLabel}
        </span>
        <span
          class="rounded-full border border-border-organic/20 bg-bg-overlay/70 px-3 py-1 font-text text-xs font-medium text-text-secondary"
        >
          Orden {entry.data.order}
        </span>
      </div>

      <div class="space-y-4">
        <h1
          class="font-title text-3xl font-extrabold text-text-primary md:text-4xl xl:text-5xl"
        >
          {entry.data.title}
        </h1>
        <p
          class="max-w-3xl font-text text-base leading-8 text-text-secondary md:text-lg"
        >
          {entry.data.description}
        </p>
      </div>

      <div
        class="flex flex-wrap gap-3 font-text text-sm text-text-secondary/85"
      >
        <span
          class="rounded-full border border-border-organic/20 bg-bg-overlay/70 px-4 py-2"
        >
          Publicado: {
            entry.data.date.toLocaleDateString("es-MX", {
              day: "2-digit",
              month: "long",
              year: "numeric",
            })
          }
        </span>
        <span
          class="rounded-full border border-border-organic/20 bg-bg-overlay/70 px-4 py-2"
        >
          ID: {entry.id}
        </span>
      </div>
    </div>

    <div class="border-t border-border-organic/15 xl:border-t-0 xl:border-l">
      {
        entry.data.coverImage ? (
          <div class="relative h-full min-h-[280px] xl:min-h-full">
            <Image
              transition:name="img1"
              src={entry.data.coverImage}
              alt={`Imagen principal de ${entry.data.title}`}
              loading="eager"
              decoding="async"
              fetchpriority="high"
              class="absolute inset-0 h-full w-full object-cover"
            />
            {/* <div class="absolute inset-0 bg-bg-overlay/60" /> */}
            {/* <div class="absolute bottom-0 left-0 right-0 p-6">
              <div class="rounded-2xl border border-border-organic/20 bg-bg-overlay/80 p-4 backdrop-blur-sm">
                <p class="font-text text-xs font-semibold uppercase tracking-[0.22em] text-accent-strong">
                  Imagen destacada
                </p>
                <p class="mt-2 font-text text-sm leading-6 text-text-secondary/90">
                  Espacio preparado para la imagen principal de esta entrada del
                  GDD.
                </p>
              </div>
            </div> */}
          </div>
        ) : (
          <div class="flex h-full min-h-[280px] items-center justify-center bg-bg-overlay/70 p-6">
            <div class="w-full max-w-sm rounded-[1.75rem] border border-dashed border-border-organic/30 bg-bg-overlay/80 p-8 text-center">
              <p class="font-text text-xs font-semibold uppercase tracking-[0.24em] text-accent-strong">
                Imagen pendiente
              </p>
              <h2 class="mt-4 font-title text-2xl font-bold text-text-primary">
                Aquí irá la portada
              </h2>
              <p class="mt-3 font-text text-sm leading-7 text-text-secondary/85">
                La plantilla ya reserva este espacio para que después agregues
                grids, composiciones visuales o la imagen predilecta de cada
                entrada.
              </p>
            </div>
          </div>
        )
      }
    </div>
  </div>

  <div class="border-t border-border-organic/15 p-6 md:p-8 lg:p-10">
    <div
      class="gdd-content prose prose-invert max-w-none
      prose-code:bg-bg-overlay/70 prose-code:border prose-code:border-border-organic/20 prose-code:rounded-lg prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm prose-code:font-mono prose-code:text-text-secondary/90 prose-td:text-text-secondary/80
      prose-blockquote:border-l-4 prose-blockquote:border-border-organic/20 prose-blockquote:bg-bg-overlay/70 prose-blockquote:pl-6 prose-blockquote:italic prose-blockquote:text-text-secondary/85
      prose-headings:font-title prose-headings:text-text-primary prose-p:font-text prose-p:text-text-secondary prose-li:font-text prose-li:text-text-secondary prose-strong:text-text-primary prose-a:text-accent-strong"
    >
      <slot />
    </div>
  </div>
</article>
