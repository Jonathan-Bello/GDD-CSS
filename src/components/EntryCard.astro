---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  id: string;
  title: string;
  description: string;
  coverImage?: ImageMetadata;
  order?: number;
}

const { id, title, description, coverImage, order } = Astro.props;
---

<a
  href={`/sistema-juego/${id}`}
  class="group relative overflow-hidden rounded-xl border border-border-organic/20 bg-bg-elevated/70 shadow-[0_28px_90px_rgba(26,26,26,0.25)] backdrop-blur transition-all duration-300 hover:border-border-organic/40 hover:shadow-[0_28px_90px_rgba(74,6,5,0.35)]"
>
  <!-- Cover Image with ViewTransition -->
  {
    coverImage && (
      <div class="relative h-48 w-full overflow-hidden bg-gradient-to-br from-bg-elevated/20 to-bg-overlay/80">
        <Image
          src={coverImage}
          alt={title}
          transition:name={`card-image-${id}`}
          width={coverImage.width}
          height={coverImage.height}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-bg-overlay to-transparent opacity-60" />
      </div>
    )
  }

  <!-- Content -->
  <div class="space-y-4 p-6">
    {
      order !== undefined && (
        <span class="inline-flex rounded-full border border-border-organic/20 bg-bg-overlay/70 px-3 py-1 font-text text-xs font-semibold uppercase tracking-[0.22em] text-accent-strong">
          Entrada {order}
        </span>
      )
    }

    <div class="space-y-2">
      <h3
        class="font-title text-xl font-bold text-text-primary transition-colors duration-300 group-hover:text-accent-strong"
      >
        {title}
      </h3>
      <p class="line-clamp-3 font-text text-sm leading-6 text-text-secondary/80">
        {description}
      </p>
    </div>

    <!-- Arrow indicator -->
    <div class="flex items-center gap-2 pt-2">
      <span
        class="font-text text-xs font-semibold uppercase tracking-[0.22em] text-accent-strong"
      >
        Ver más
      </span>
      <svg
        class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </div>
  </div>
</a>
