---
import {
  BoltIcon,
  CpuChipIcon,
  PlayIcon,
  TrophyIcon,
} from "@heroicons/react/24/outline";

const features = [
  {
    title: "Aprende Jugando",
    description:
      "Supera retos interactivos, desbloquea niveles y conviértete en mejor desarrollador mientras avanzas dentro del juego.",
    icon: PlayIcon,
  },
  {
    title: "IA Personalizada",
    description:
      "Recibe retroalimentación instantánea y sugerencias alineadas con tu progreso para mejorar cada ejercicio.",
    icon: CpuChipIcon,
  },
  {
    title: "Objetivos Claros",
    description:
      "Cada misión tiene metas concretas para que construyas habilidades CSS de forma ordenada y medible.",
    icon: TrophyIcon,
  },
  {
    title: "Progreso Rápido",
    description:
      "Visualiza tus avances desde el primer día con una experiencia pensada para mantener el ritmo y la motivación.",
    icon: BoltIcon,
  },
];
---

<section class="bg-bg-base py-20 sm:py-24">
  <div class="container mx-auto px-4 md:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <span
        class="font-text text-sm font-semibold uppercase tracking-[0.3em] text-accent-strong"
      >
        ¿Por qué CSS Quest AI?
      </span>
      <h2
        class="mt-4 font-title text-3xl font-extrabold text-text-primary sm:text-4xl md:text-5xl"
      >
        Una forma más dinámica de dominar CSS
      </h2>
      <p class="mt-6 font-text text-lg leading-8 text-text-secondary sm:text-xl">
        Diseñamos una experiencia que combina videojuego, acompañamiento
        inteligente y objetivos bien definidos para que aprender CSS se sienta
        retador, útil y emocionante.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-4 md:grid-cols-2">
      {
        features.map(({ icon: Icon, title, description }) => (
          <article class="group overflow-hidden rounded-[2rem] border border-border-organic/20 bg-bg-elevated/70 shadow-[0_28px_90px_rgba(26,26,26,0.25)] backdrop-blur p-8 transition duration-300 hover:-translate-y-1 hover:border-border-organic/45 hover:shadow-[0_28px_90px_rgba(26,26,26,0.35)]">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-accent shadow-[0_12px_30px_rgba(242,158,7,0.35)] transition duration-300 group-hover:scale-105 group-hover:bg-accent-strong">
              <Icon className="h-8 w-8 text-text-primary" />
            </div>

            <h3 class="mt-6 font-title text-2xl font-bold text-text-primary">
              {title}
            </h3>

            <p class="mt-4 font-text text-lg leading-8 text-text-secondary">
              {description}
            </p>
          </article>
        ))
      }
    </div>
  </div>


</section>
