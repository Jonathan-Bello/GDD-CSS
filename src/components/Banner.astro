---
import heroGameImage from "@assets/imgs/main.webp";
---

<section
  class="relative overflow-hidden bg-gradient-to-b from-bg-overlay via-bg-base to-bg-elevated"
>
  <div class="container mx-auto px-4 py-16 md:px-6 lg:py-24">
    <div
      class="grid items-center gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.9fr)] lg:gap-16"
    >
      <div class="space-y-6">
        <span
          class="ds-panel
        inline-flex items-center gap-2 rounded-full px-4 py-2 font-text text-sm font-semibold
        text-text-secondary"
        >
          ✨ Aprendizaje potenciado por IA
        </span>

        <h1
          class="font-title text-4xl font-extrabold leading-tight text-text-primary sm:text-5xl md:text-6xl"
        >
          Domina CSS
          <span class="block text-accent-strong">Jugando</span>
        </h1>

        <p
          class="max-w-xl font-text text-lg leading-relaxed text-text-secondary md:text-2xl"
        >
          Citadel of Solar Souls es un videojuego educativo revolucionario que
          combina mecánicas de juego adictivas con inteligencia artificial para
          convertirte en un experto en CSS.
        </p>

        <div class="flex flex-col gap-4 pt-2 sm:flex-row sm:items-center">
          <a
            href="/gdd/"
            class="inline-flex justify-center rounded-xl bg-accent px-8 py-4 font-text text-lg font-semibold text-text-inverse shadow-[0_0_30px_rgba(242,158,7,0.35)] transition hover:bg-accent-strong"
          >
            Ver documentación
          </a>
          <a
            href="/sobre-nosotros/"
            class="ds-panel ds-panel--blur inline-flex justify-center rounded-xl px-8 py-4 font-text text-lg font-semibold text-text-primary transition hover:bg-text-primary/20"
          >
            Conocer más
          </a>
        </div>
      </div>
      <div class="relative">
        <div
          class="absolute -inset-4 rounded-[2rem] bg-[radial-gradient(circle_at_top,#f29e0728,transparent_60%)] blur-2xl"
        >
        </div>
        <div
          class="relative overflow-hidden rounded-[2rem] border border-border-organic/20 bg-bg-overlay/70 p-6 shadow-[0_28px_90px_rgba(26,26,26,0.35)] backdrop-blur"
        >
          <img
            src={heroGameImage.src}
            alt="Logo principal de Citadel of Solar Souls"
            class="h-full w-full rounded-[1.4rem] object-contain"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>
</section>
