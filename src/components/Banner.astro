---
import { Image } from "astro:assets";

import imgFigma from "../assets/imgs/figma.jpg";
---

<section
  class="relative overflow-hidden bg-gradient-to-b from-primary-950 via-primary-900 to-primary-800"
>
  <div class="container mx-auto px-4 py-16 md:px-6 lg:py-24">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="space-y-6">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-primary-300/50 bg-primary-700/40 px-4 py-2 font-text text-sm font-semibold text-primary-100"
        >
          ✨ Aprendizaje potenciado por IA
        </span>

        <h1
          class="font-title text-4xl font-extrabold leading-tight text-neutral-50 sm:text-5xl md:text-6xl"
        >
          Domina CSS
          <span class="block text-primary-300">Jugando</span>
        </h1>

        <p
          class="max-w-xl font-text text-lg leading-relaxed text-neutral-100 md:text-2xl"
        >
          CSS Quest AI es un videojuego educativo revolucionario que combina
          mecánicas de juego adictivas con inteligencia artificial para
          convertirte en un experto en CSS.
        </p>

        <div class="flex flex-col gap-4 pt-2 sm:flex-row sm:items-center">
          <a
            href="/gdd"
            class="inline-flex justify-center rounded-xl bg-primary-500 px-8 py-4 font-text text-lg font-semibold text-neutral-50 shadow-[0_0_30px_rgba(253,56,54,0.35)] transition hover:bg-primary-400"
          >
            Ver documentación
          </a>
          <a
            href="/sobre-nosotros"
            class="inline-flex justify-center rounded-xl border border-neutral-100/30 bg-neutral-50/10 px-8 py-4 font-text text-lg font-semibold text-neutral-50 backdrop-blur transition hover:bg-neutral-50/20"
          >
            Conocer más
          </a>
        </div>
      </div>

      <div>
        <Image
          src={imgFigma}
          alt="Dispositivos de trabajo para aprendizaje digital"
          class="h-full max-h-[500px] w-full rounded-3xl object-cover shadow-2xl ring-1 ring-neutral-50/15"
        />
      </div>
    </div>
  </div>
</section>
